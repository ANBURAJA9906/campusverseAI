// --------------------------------------------------------------------------
// MySQL migration notes (read this before switching providers):
//
// This schema currently targets SQLite for local dev, per DATABASE_URL in
// .env. To move to MySQL for deployment:
//   1. Set provider below to "mysql" and point DATABASE_URL at your MySQL
//      instance, e.g. mysql://user:password@host:3306/campusverse
//   2. Add `@db.Text` to the String fields below that can hold long free
//      text — MySQL's Prisma connector defaults untyped String columns to
//      VARCHAR(191), which will silently truncate anything longer (SQLite
//      has no such limit, which is why this hasn't been an issue yet):
//        Club.description, Event.description, Announcement.content,
//        Hostel.facilities, CommunityPost.content, CommunityComment.content,
//        StudyPlan.tasks (JSON-stringified — can get long), Entity.description
//   3. Run `npx prisma migrate dev` (not `db push`) against the new
//      datasource once you're on a shared/production database, so schema
//      changes are tracked as migrations instead of ad-hoc pushes.
//   4. All @id fields already use String @default(uuid()), which MySQL
//      stores fine as VARCHAR(36) — no change needed there.
// --------------------------------------------------------------------------
datasource db {
     provider = "postgresql"
     url      = env("DATABASE_URL")
   }
generator client {
  provider = "prisma-client-js"
}

model Student {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  department    String
  year          Int
  cgpa          Float
  interests     String         // Comma-separated interests
  skills        String         // Comma-separated skills
  registrations Registration[]
  studyPlans    StudyPlan[]
  memories      Memory[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
}

model Club {
  id            String         @id @default(uuid())
  name          String
  description   String
  category      String
  whatsappGroup String
  createdById   String?
  createdBy     Staff?         @relation(fields: [createdById], references: [id])
  registrations Registration[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Event {
  id            String         @id @default(uuid())
  name          String
  description   String
  date          String
  type          String         // "hackathon", "workshop", "orientation", "placement_drive"
  deadline      String
  location      String
  createdById   String?
  createdBy     Staff?         @relation(fields: [createdById], references: [id])
  registrations Registration[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  date        String
  category    String   // "general", "academic", "placement", "exam"
  summarized  String
  createdById String?
  createdBy   Staff?   @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

// Office staff / faculty accounts. Separate from Student — this is the
// authenticated identity behind the Admin/Faculty portal.
model Staff {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          String         @default("ADMIN") // "ADMIN" | "FACULTY"
  department    String?
  createdAt     DateTime       @default(now())
  clubs         Club[]
  events        Event[]
  announcements Announcement[]
  hostels       Hostel[]
  libraryBooks  LibraryBook[]
}

// Smart Library & Hostel Information — submitted-feature #9
model Hostel {
  id          String   @id @default(uuid())
  name        String
  type        String   // "Boys", "Girls", "Co-ed"
  warden      String
  contact     String
  messTimings String   // e.g. "Breakfast 7:30-9:30, Lunch 12:30-2:30, Dinner 7:30-9:30"
  facilities  String   // comma-separated, e.g. "WiFi, Laundry, Gym, Study Room"
  location    String
  createdById String?
  createdBy   Staff?   @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model LibraryBook {
  id            String   @id @default(uuid())
  title         String
  author        String
  category      String   // "Textbook", "Reference", "Journal", "Fiction"
  callNumber    String
  totalCopies   Int      @default(1)
  availableCopies Int    @default(1)
  createdById   String?
  createdBy     Staff?   @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
}

// AI Senior Mentor Community — submitted-feature #3
model CommunityPost {
  id        String            @id @default(uuid())
  studentId String
  title     String
  content   String
  tags      String            // comma-separated, e.g. "DSA, Placements"
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  comments  CommunityComment[]
  createdAt DateTime          @default(now())
}

model CommunityComment {
  id        String        @id @default(uuid())
  postId    String
  studentId String
  content   String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

model Registration {
  id        String   @id @default(uuid())
  studentId String
  clubId    String?
  eventId   String?
  date      String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  club      Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model StudyPlan {
  id        String   @id @default(uuid())
  studentId String
  subject   String
  date      String   // Target Exam Date
  tasks     String   // JSON string representing tasks/days schedule
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Memory {
  id        String   @id @default(uuid())
  studentId String
  key       String
  value     String
  category  String   // "preference", "interest", "chat_history", "goal"
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Entity {
  id          String   @id @default(uuid())
  type        String   // "Student", "Faculty", "Lab", "Club", "Event", "Subject", "Department"
  name        String
  description String
}

model Relation {
  id       String @id @default(uuid())
  sourceId String
  targetId String
  type     String // "MEMBER_OF", "TEACHES", "LOCATED_IN", "HAS_EXAM_ON", "ORGANIZED_BY", "REQUIRES_SKILL"
}

// Real per-query intent log, written once by plannerAgent.js on every
// orchestrateQuery call. Backs the "AI Specialized Agent Usage" panel in
// /api/analytics with actual counts instead of hardcoded demo numbers —
// it starts at zero and grows as the app is actually used.
model QueryLog {
  id        String   @id @default(uuid())
  intent    String
  createdAt DateTime @default(now())
}
